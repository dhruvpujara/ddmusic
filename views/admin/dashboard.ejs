<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - DDMusic</title>
    <link rel="stylesheet" href="/css/output.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-900 text-white min-h-screen">
    <div class="max-w-4xl mx-auto p-6">
        <h1 class="text-2xl font-bold mb-8">Song Management</h1>

        <!-- Search Form -->
        <div class="mb-8">
            <input type="text" 
                   id="searchInput" 
                   placeholder="Search song by name..." 
                   class="w-full bg-gray-800 text-white px-4 py-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
        </div>

        <!-- Results Section -->
        <div id="resultsSection" class="space-y-4"></div>
    </div>

    <script>
        const searchInput = document.getElementById('searchInput');
        const resultsSection = document.getElementById('resultsSection');

        let searchTimeout;
        searchInput.addEventListener('input', () => {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(searchSongs, 500);
        });

        async function searchSongs() {
            const query = searchInput.value;
            if (!query) {
                resultsSection.innerHTML = '';
                return;
            }

            try {
                const response = await fetch(`/admin/search-song?name=${encodeURIComponent(query)}`);
                const songs = await response.json();
                displayResults(songs);
            } catch (err) {
                console.error('Error searching songs:', err);
            }
        }

        function displayResults(songs) {
            resultsSection.innerHTML = songs.map(song => `
                <div class="bg-gray-800 rounded-lg p-4" id="song-${song._id}">
                    <div class="flex justify-between items-start mb-4">
                        <input type="text" value="${song.name}" 
                               class="bg-gray-700 text-white px-3 py-2 rounded w-full mr-4"
                               id="name-${song._id}">
                        <button onclick="deleteSong('${song._id}')"
                                class="bg-red-500 hover:bg-red-600 px-4 py-2 rounded">
                            Delete
                        </button>
                    </div>
                    <input type="text" value="${song.link}" 
                           class="bg-gray-700 text-white px-3 py-2 rounded w-full mb-2"
                           id="link-${song._id}">
                    <input type="text" value="${song.hashtags.join(', ')}" 
                           class="bg-gray-700 text-white px-3 py-2 rounded w-full mb-4"
                           id="hashtags-${song._id}">
                    <button onclick="updateSong('${song._id}')"
                            class="bg-purple-500 hover:bg-purple-600 px-6 py-2 rounded">
                        Update
                    </button>
                </div>
            `).join('');
        }

        async function updateSong(id) {
            const songData = {
                id,
                name: document.getElementById(`name-${id}`).value,
                link: document.getElementById(`link-${id}`).value,
                hashtags: document.getElementById(`hashtags-${id}`).value.split(',').map(tag => tag.trim())
            };

            try {
                const response = await fetch('/admin/update-song', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(songData)
                });

                if (response.ok) {
                    alert('Song updated successfully');
                }
            } catch (err) {
                console.error('Error updating song:', err);
            }
        }

        async function deleteSong(id) {
            if (!confirm('Are you sure you want to delete this song?')) return;

            try {
                const response = await fetch(`/admin/delete-song/${id}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    document.getElementById(`song-${id}`).remove();
                }
            } catch (err) {
                console.error('Error deleting song:', err);
            }
        }
    </script>
</body>
</html>
