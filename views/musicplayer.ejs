<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Now Playing - DDMusic</title>
    <link rel="stylesheet" href="/css/output.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-black min-h-screen flex flex-col text-white">
    <!-- Header -->
    <header class="fixed top-0 w-full bg-black/90 backdrop-blur-lg z-50 px-4 py-3 border-b border-gray-800">
        <div class="flex items-center">
            <a href="/" class="text-white mr-4"><i class="fas fa-arrow-left"></i></a>
            <h1 class="text-xl font-bold">Now Playing</h1>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 mt-16 mb-32 px-4 flex flex-col items-center">
        <!-- Album Art -->
        <div class="w-64 h-64 md:w-80 md:h-80 rounded-lg bg-gradient-to-br from-purple-600 to-blue-600 mt-8 mb-8 shadow-2xl relative overflow-hidden group">
            <!-- Like Button Form -->
            <form action="/like" method="POST" class="absolute top-4 left-4 z-10">
                <!-- Make sure the field name matches what the controller expects -->
                <input type="hidden" name="objectId" value="<%= songId %>">
                <button type="submit" 
                    class="w-12 h-12 rounded-full bg-black/40 backdrop-blur-md 
                           flex items-center justify-center 
                           hover:bg-pink-500/20 hover:scale-110
                           active:scale-95
                           transform transition-all duration-300 ease-in-out
                           group shadow-lg hover:shadow-pink-500/25">
                    <i class="fas fa-heart text-2xl 
                             text-white/60 group-hover:text-pink-500 
                             transition-all duration-300
                             group-hover:scale-110"></i>
                </button>
            </form>
            
            <!-- Animated Music Notes -->
            <div class="absolute inset-0 flex items-center justify-center">
                <i class="fas fa-music text-6xl text-white/30 animate-pulse"></i>
            </div>
            <!-- Floating Circles -->
            <div class="absolute w-40 h-40 rounded-full bg-white/5 -top-20 -left-20 animate-blob"></div>
            <div class="absolute w-40 h-40 rounded-full bg-purple-500/10 -bottom-20 -right-20 animate-blob animation-delay-2000"></div>
            <!-- Equalizer Bars -->
            <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-1">
                <div class="w-1 h-8 bg-white/20 rounded-full animate-eq"></div>
                <div class="w-1 h-12 bg-white/20 rounded-full animate-eq animation-delay-200"></div>
                <div class="w-1 h-6 bg-white/20 rounded-full animate-eq animation-delay-400"></div>
                <div class="w-1 h-10 bg-white/20 rounded-full animate-eq animation-delay-600"></div>
            </div>
            <!-- Hover Effect -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </div>

        <!-- Song Info -->
        <div class="text-center mb-8 w-full max-w-md">
            <h2 class="text-2xl font-bold mb-2"><%=songName%></h2>
            <p class="text-gray-400">DDMusic Player</p>
        </div>

        <!-- Custom Audio Player -->
        <div class="w-full max-w-md mb-6 bg-gray-900/30 backdrop-blur p-4 rounded-xl border border-gray-800">
            <audio id="audioPlayer" class="hidden">
                <source src="<%= songLink %>" type="audio/mp3">
            </audio>

            <!-- Progress Bar -->
            <div class="w-full bg-gray-800 rounded-full h-1.5 mb-4 cursor-pointer" id="progressBar">
                <div class="bg-purple-600 h-1.5 rounded-full" id="progress" style="width: 0%"></div>
            </div>

            <div class="flex items-center justify-between">
                <!-- Time Display -->
                <span id="currentTime" class="text-sm text-gray-400">0:00</span>

                <!-- Controls -->
                <div class="flex items-center gap-6">
                    <button class="text-white/80 hover:text-white transition-colors">
                        <i class="fas fa-backward-step text-xl"></i>
                    </button>
                    <button id="playPauseBtn" 
                            class="w-12 h-12 rounded-full bg-purple-600 
                                   flex items-center justify-center 
                                   hover:bg-purple-700 hover:scale-105
                                   active:scale-95 transition-all duration-200">
                        <i class="fas fa-play text-xl pl-1"></i>
                    </button>
                    <button class="text-white/80 hover:text-white transition-colors">
                        <i class="fas fa-forward-step text-xl"></i>
                    </button>
                </div>

                <!-- Duration -->
                <span id="duration" class="text-sm text-gray-400">0:00</span>
            </div>
        </div>

        <script>
            const audio = document.getElementById('audioPlayer');
            const playPauseBtn = document.getElementById('playPauseBtn');
            const progressBar = document.getElementById('progressBar');
            const progress = document.getElementById('progress');
            const currentTimeEl = document.getElementById('currentTime');
            const durationEl = document.getElementById('duration');

            // Play/Pause functionality
            playPauseBtn.addEventListener('click', () => {
                if (audio.paused) {
                    audio.play();
                    playPauseBtn.innerHTML = '<i class="fas fa-pause text-xl"></i>';
                } else {
                    audio.pause();
                    playPauseBtn.innerHTML = '<i class="fas fa-play text-xl pl-1"></i>';
                }
            });

            // Update progress and time
            audio.addEventListener('timeupdate', () => {
                const percent = (audio.currentTime / audio.duration) * 100;
                progress.style.width = `${percent}%`;
                currentTimeEl.textContent = formatTime(audio.currentTime);
            });

            // Click to seek
            progressBar.addEventListener('click', (e) => {
                const rect = progressBar.getBoundingClientRect();
                const percent = (e.clientX - rect.left) / rect.width;
                audio.currentTime = percent * audio.duration;
            });

            // Set duration
            audio.addEventListener('loadedmetadata', () => {
                durationEl.textContent = formatTime(audio.duration);
            });

            // Format time helper
            function formatTime(seconds) {
                const minutes = Math.floor(seconds / 60);
                const remainingSeconds = Math.floor(seconds % 60);
                return `${minutes}:${remainingSeconds.toString().padStart(2, '0')}`;
            }
        </script>
    </main>
</body>
</html>