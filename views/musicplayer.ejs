<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Now Playing - DDMusic</title>
    <link rel="stylesheet" href="output.css" >
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-black min-h-screen flex flex-col text-white">
    <!-- Header -->
    <header class="fixed top-0 w-full bg-black/90 backdrop-blur-lg z-50 px-4 py-3 border-b border-gray-800">
        <div class="flex items-center">
            <a href="/" class="text-white mr-4"><i class="fas fa-arrow-left"></i></a>
            <h1 class="text-xl font-bold">Now Playing</h1>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 mt-16 mb-32 px-4 flex flex-col items-center">
        <!-- Album Art -->
        <div class="w-64 h-64 md:w-80 md:h-80 rounded-lg bg-gradient-to-br from-purple-600 to-blue-600 mt-8 mb-8 shadow-2xl relative overflow-hidden group">
            <!-- Animated Music Notes -->
            <div class="absolute inset-0 flex items-center justify-center">
                <i class="fas fa-music text-6xl text-white/30 animate-pulse"></i>
            </div>
            <!-- Floating Circles -->
            <div class="absolute w-40 h-40 rounded-full bg-white/5 -top-20 -left-20 animate-blob"></div>
            <div class="absolute w-40 h-40 rounded-full bg-purple-500/10 -bottom-20 -right-20 animate-blob animation-delay-2000"></div>
            <!-- Equalizer Bars -->
            <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-1">
                <div class="w-1 h-8 bg-white/20 rounded-full animate-eq"></div>
                <div class="w-1 h-12 bg-white/20 rounded-full animate-eq animation-delay-200"></div>
                <div class="w-1 h-6 bg-white/20 rounded-full animate-eq animation-delay-400"></div>
                <div class="w-1 h-10 bg-white/20 rounded-full animate-eq animation-delay-600"></div>
            </div>
            <!-- Hover Effect -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </div>

        <!-- Song Info -->
        <div class="text-center mb-8 w-full max-w-md">
            <h2 class="text-2xl font-bold mb-2"><%=songName%></h2>
            <p class="text-gray-400">Archive.org</p>
        </div>

        <!-- Fallback Audio Player -->
        <div class="w-full max-w-md mb-6">
            <!-- Primary Player -->
            <iframe 
                src="<%= songLink %>" 
                width="100%" 
                height="50" 
                frameborder="0"
            ></iframe>
            
            <!-- Fallback Player -->
            <audio 
                controls 
                class="w-full mt-2 hidden" 
                id="fallbackPlayer"
                onError="this.classList.remove('hidden')"
            >
                <source src="https://archive.org/download/apa-fer-milaange-320-pagai-world.com/apa-fer-milaange-320-pagai-world.com.mp3" type="audio/mpeg">
            </audio>
        </div>
    </main>
</body>
</html>