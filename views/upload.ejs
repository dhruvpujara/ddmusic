<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload - DDMusic</title>
    <link rel="stylesheet" href="output.css">
</head>
<body class="bg-black min-h-screen text-white p-8">
    <div class="max-w-md mx-auto">
        <h1 class="text-2xl font-bold mb-6">Upload Song</h1>
        <form action="/admin/upload" method="POST" class="space-y-4">
            <div>
                <label class="block mb-2">Song Name</label>
                <input type="text" name="name" required class="w-full p-2 rounded bg-gray-800 text-white">
            </div>
            <div>
                <label class="block mb-2">Song Link</label>
                <input type="text" name="link" required class="w-full p-2 rounded bg-gray-800 text-white">
            </div>
            <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
                Upload
            </button>
        </form>
    </div>
</body>
</html>
