<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DDMusic Mobile</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-black min-h-screen flex flex-col">
    <!-- Top Bar -->
    <header class="fixed top-0 w-full bg-black/90 backdrop-blur-lg z-50 px-4 py-3 border-b border-gray-800">
        <div class="flex justify-between items-center">
            <h1 class="text-xl font-bold text-white">DDMusic</h1>
            <button class="text-gray-400"><i class="fas fa-search"></i></button>
        </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-1 mt-16 mb-32 px-4">
        <!-- Featured Section -->
        <section class="py-4">
            <h2 class="text-white text-lg font-semibold mb-3">Featured Playlists</h2>
            <div class="flex overflow-x-auto space-x-4 pb-4">
                <a href="/playbollywood" class="flex-shrink-0 w-32 hover:opacity-80 transition-opacity">
                    <div class="bg-gradient-to-br from-rose-400 via-pink-400 to-violet-400 aspect-square rounded-lg mb-2 relative overflow-hidden group">
                        <i class="fas fa-film absolute text-3xl text-white/30 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 group-hover:scale-110 transition-transform"></i>
                    </div>
                    <p class="text-white text-sm">Bollywood</p>
                </a>
                <a href="/oldies" class="flex-shrink-0 w-32 hover:opacity-80 transition-opacity">
                    <div class="bg-gradient-to-br from-cyan-400 via-teal-400 to-emerald-400 aspect-square rounded-lg mb-2 relative overflow-hidden group">
                        <i class="fas fa-record-vinyl absolute text-3xl text-white/30 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 group-hover:rotate-45 transition-transform"></i>
                    </div>
                    <p class="text-white text-sm">Retro</p>
                </a>
                <div class="flex-shrink-0 w-32">
                    <div class="bg-gradient-to-br from-indigo-400 via-blue-400 to-sky-400 aspect-square rounded-lg mb-2 relative overflow-hidden group">
                        <i class="fas fa-moon absolute text-3xl text-white/30 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 group-hover:scale-110 transition-transform"></i>
                    </div>
                    <p class="text-white text-sm">Chill Mix</p>
                </div>
            </div>
        </section>

        <!-- Recently Played -->
        <section class="py-4">
            <h2 class="text-white text-lg font-semibold mb-3">Recently Played</h2>
            <div class="space-y-3">
                <% if (recentSong) { %>
                    <form action="/player" method="POST" class="block">
                        <input type="hidden" name="songLink" value="<%= recentSong.link %>">
                        <input type="hidden" name="songName" value="<%= recentSong.name %>">
                        <input type="hidden" name="objectId" value="<%= recentSong._id %>">
                        <button type="submit" class="w-full">
                            <div class="flex items-center space-x-3 bg-gray-900/50 p-4 rounded-lg hover:bg-gray-800/50 transition-colors">
                                <div class="w-12 h-12 bg-gradient-to-br from-purple-400 to-blue-400 rounded-lg flex items-center justify-center">
                                    <i class="fas fa-music text-lg text-white/80"></i>
                                </div>
                                <div class="flex-1">
                                    <p class="text-white text-sm font-medium text-left"><%= recentSong.name %></p>
                                    <p class="text-gray-400 text-xs text-left">Last played</p>
                                </div>
                                <i class="fas fa-play text-gray-400 text-sm"></i>
                            </div>
                        </button>
                    </form>
                <% } else { %>
                    <div class="flex items-center space-x-3 bg-gray-900/50 p-4 rounded-lg opacity-50">
                        <div class="w-12 h-12 bg-gray-800 rounded-lg flex items-center justify-center">
                            <i class="fas fa-music text-lg text-white/50"></i>
                        </div>
                        <p class="text-gray-400 text-sm">No recent songs</p>
                    </div>
                <% } %>
            </div>
        </section>
    </main>

    <!-- Now Playing Bar -->
    <!-- <div class="fixed bottom-16 left-0 right-0 bg-gray-900/90 backdrop-blur-lg border-t border-gray-800 p-3">
        <div class="flex items-center justify-between">
            <a href="/player" class="flex items-center space-x-3 flex-1">
                <div class="w-10 h-10 bg-gray-800 rounded"></div>
                <div>
                    <p class="text-white text-sm">Current Song</p>
                    <p class="text-gray-400 text-xs">Artist</p>
                </div>
            </a>
            <div class="flex items-center space-x-4">
                <button class="text-white p-2"><i class="fas fa-play"></i></button>
                <button class="text-white p-2"><i class="fas fa-forward"></i></button>
            </div>
        </div>
    </div> -->

    <!-- Bottom Navigation -->
   <nav class="fixed bottom-0 w-full bg-black/90 backdrop-blur-lg border-t border-gray-800">
        <div class="flex justify-around py-3">
            <a href="/" class="text-white flex flex-col items-center">
                <i class="fas fa-home"></i>
                <span class="text-xs mt-1">Home</span>
            </a>
            <a href="/explore" class="text-gray-400 flex flex-col items-center">
                <i class="fas fa-compass"></i>
                <span class="text-xs mt-1">Explore</span>
            </a>
            <a href="/library" class="text-gray-400 flex flex-col items-center">
                <i class="fas fa-heart"></i>
                <span class="text-xs mt-1">Library</span>
            </a>
            <a href="/profile" class="text-gray-400 flex flex-col items-center">
                <i class="fas fa-user"></i>
                <span class="text-xs mt-1">Profile</span>
            </a>
        </div>
    </nav>
</body>
</html>